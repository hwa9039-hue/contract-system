# ── 로컬 개발 (npm run dev) ─────────────────────────────────────────────
# API 주소는 src/apiClient.js 에서 http://localhost:8000 으로 고정됩니다.
# (public/api-config.js 는 dev 에서 로드되지 않습니다.)
#
# ── 운영 빌드 (npm run build) ─────────────────────────────────────────
# 운영 API: public/api-config.js 의 __CMS_API_BASE_URL__
# 백엔드 AUTH_SHARED_PASSWORD와 동일하게 맞추세요.
VITE_APP_SHARED_PASSWORD=smartdi2026!
VITE_APP_ADMIN_PASSWORD=admin2026!
# 부서장(MANAGER) 비밀번호 — 백엔드 AUTH_MANAGER_PASSWORD와 동일하게 맞추세요.
# UI 부서장 탭은 없고, '일반 사용자' 탭에서 이 비밀번호를 입력하면 부서장 권한으로 로그인됩니다.
VITE_APP_MANAGER_PASSWORD=kk2331!

# (선택) 빌드에 포함 시 콘솔에 API 헬스·로그인 단계 로그. 운영에서는 보통 비우고
# 브라우저에서 ?cmsApiProbe=1 로 켜는 방식을 권장합니다.
# VITE_CMS_API_PROBE=true

# 건축정보 POST 실패 시에만 로컬 저장 폴백(기본 false). 강제 mock: true
# VITE_DISCOVERY_API_MOCK=true

# (선택) MUI X Data Grid Pro 라이선스 키 — 단가관리 Tree Grid
# VITE_MUI_X_LICENSE_KEY=

