# ── 로컬 개발 (npm run dev) ─────────────────────────────────────────────
# API 주소는 src/apiClient.js 에서 http://localhost:8000 으로 고정됩니다.
# (public/api-config.js 는 dev 에서 로드되지 않습니다.)
#
# ── 운영 빌드 (npm run build) ─────────────────────────────────────────
# 운영 API: public/api-config.js 의 __CMS_API_BASE_URL__
# 백엔드 AUTH_SHARED_PASSWORD와 동일하게 맞추세요.
VITE_APP_SHARED_PASSWORD=smartdi2026!

# (선택) 빌드에 포함 시 콘솔에 API 헬스·로그인 단계 로그. 운영에서는 보통 비우고
# 브라우저에서 ?cmsApiProbe=1 로 켜는 방식을 권장합니다.
# VITE_CMS_API_PROBE=true

# 건축정보 API: 운영 서버에 /api/project-discovery 배포 전까지 mock (기본 PROD=true).
# 로컬 백엔드로 실제 저장·조회 테스트 시 dev 빌드/프리뷰에서 false.
# VITE_DISCOVERY_API_MOCK=false

