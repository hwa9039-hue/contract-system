DATABASE_URL=postgresql://smartdi:Smartdi2025!@192.168.0.100:5433/smartdi
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://contract-system-2ev.pages.dev,https://contract.signtelecom-smartdi.com

# (선택) NAS 백업 — PostgreSQL Docker 컨테이너 이름 (미설정 시 자동 탐지)
# POSTGRES_DOCKER_CONTAINER=your-postgres-container-name

# (선택) NAS 백업 — API 컨테이너·업로드 경로·호스트 데이터 폴더
# BACKUP_APP_DOCKER_CONTAINER=contract-backend
# BACKUP_UPLOAD_CONTAINER_PATHS=/app/uploads,/app/data/uploads
# BACKUP_HOST_PATHS=backend/postgres_data,backend/uploads
# BACKUP_SKIP_FILE_COPY=false
# BACKUP_DIR=/volume1/backup/contract-db

# 계약 엑셀 import 성공 시 서버에서 역생성 저장 (.xlsx) — NAS backup-postgres 파일 복사 대상 폴더로 지정 가능
# Docker 예: 호스트 경로 마운트 후 /data/contract_excel_backup 등
# CONTRACT_IMPORT_EXCEL_BACKUP_DIR=/volume1/backup/contract-excel-import

# API 인증 (프로덕션 필수). JWT_SECRET은 긴 무작위 문자열로 설정하세요.
JWT_SECRET=change-me-to-a-long-random-secret
AUTH_SHARED_PASSWORD=smartdi2026!

# 로컬 개발에서만 API JWT 검사를 끄려면 true
AUTH_DISABLED=false
