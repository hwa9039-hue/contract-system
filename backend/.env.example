DATABASE_URL=postgresql://smartdi:Smartdi2025!@192.168.0.100:5433/smartdi
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://contract-system-2ev.pages.dev,https://contract.signtelecom-smartdi.com,https://contract.smart-di.com

# (선택) NAS 백업 — PostgreSQL Docker 컨테이너 이름 (미설정 시 자동 탐지)
# POSTGRES_DOCKER_CONTAINER=your-postgres-container-name

# (선택) NAS 백업 — API 컨테이너·업로드 경로·호스트 데이터 폴더
# BACKUP_APP_DOCKER_CONTAINER=contract-backend
# BACKUP_UPLOAD_CONTAINER_PATHS=/app/uploads,/app/data/uploads
# BACKUP_HOST_PATHS=backend/postgres_data,backend/uploads,backend/data/contract_excel_backup
# BACKUP_SKIP_FILE_COPY=false
# BACKUP_DIR=/volume1/docker/contract-backend/backups
# docker-compose 볼륨: ../backups:/app/backups (backend 상위 폴더, 경로 끝 공백 없이)

# 계약 엑셀 import 성공 시 서버에서 역생성 저장 (.xlsx)
# docker-compose 기본: ./data/contract_excel_backup → 컨테이너 /data/contract_excel_backup
CONTRACT_IMPORT_EXCEL_BACKUP_DIR=/data/contract_excel_backup

# API 인증 (프로덕션 필수). JWT_SECRET은 긴 무작위 문자열로 설정하세요.
JWT_SECRET=change-me-to-a-long-random-secret
AUTH_SHARED_PASSWORD=smartdi2026!
AUTH_ADMIN_PASSWORD=admin2026!
# 부서장(MANAGER) 비밀번호 — 프론트 VITE_APP_MANAGER_PASSWORD와 동일하게 맞추세요.
# UI 부서장 탭은 없고, '일반 사용자' 탭에서 이 비밀번호를 입력하면 부서장 권한으로 로그인됩니다.
AUTH_MANAGER_PASSWORD=kk2331!

# 로컬 개발에서만 API JWT 검사를 끄려면 true
AUTH_DISABLED=false

# 게시판 첨부파일 저장 경로 (Docker: /app/uploads, compose 볼륨 ./uploads:/app/uploads)
UPLOAD_DIR=/app/uploads
