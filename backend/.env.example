DATABASE_URL=postgresql://smartdi:Smartdi2025!@192.168.0.100:5433/smartdi
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://contract-system-2ev.pages.dev,https://contract.signtelecom-smartdi.com

# (선택) NAS 백업 scripts/backup-postgres.sh — PostgreSQL Docker 컨테이너 이름
# 미설정 시: DATABASE_URL 포트(예 5433) publish 컨테이너 → postgres 이미지 순으로 자동 탐지
# contract-backend 는 API 전용이므로 넣지 마세요. NAS SSH: docker ps --format '{{.Names}}\t{{.Image}}'
# POSTGRES_DOCKER_CONTAINER=your-postgres-container-name
# BACKUP_DIR=/volume1/backup/contract-db

# API 인증 (프로덕션 필수). JWT_SECRET은 긴 무작위 문자열로 설정하세요.
JWT_SECRET=change-me-to-a-long-random-secret
AUTH_SHARED_PASSWORD=smartdi2026!

# 로컬 개발에서만 API JWT 검사를 끄려면 true
AUTH_DISABLED=false
